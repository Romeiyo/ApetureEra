<section class="featured-collections">
  <div class="featured-collections__container">
    {% if section.settings.heading %}
      <h2 class="featured-collections__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading %}
      <p class="featured-collections__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="featured-collections__grid">
      {% for block in section.blocks %}
        {% if block.settings.collection %}
          {% assign collection = collections[block.settings.collection] %}
          
          <div 
            class="collection-card"
            {{ block.shopify_attributes }}
          >
            <div class="collection-card__image-wrapper">
              {% if collection.image %}
                <img 
                  src="{{ collection.image | image_url: width: 600 }}"
                  alt="{{ collection.image.alt }}"
                  class="collection-card__image"
                  width="600"
                  height="600"
                >
              {% elsif collection.products.first.featured_image %}
                <img 
                  src="{{ collection.products.first.featured_image | image_url: width: 600 }}"
                  alt="{{ collection.products.first.featured_image.alt }}"
                  class="collection-card__image"
                  width="600"
                  height="600"
                >
              {% else %}
                <div class="collection-card__placeholder">No Image</div>
              {% endif %}
            </div>

            <div class="collection-card__content">
              <h3 class="collection-card__title">{{ collection.title }}</h3>
              <p class="collection-card__count">{{ collection.products_count }} products</p>
              
              <a href="{{ collection.url }}" class="collection-card__button">
                {{ block.settings.button_text }}
              </a>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.blocks.size == 0 %}
      <p style="text-align: center; color: #999;">
        Add collection blocks to display featured collections.
      </p>
    {% endif %}
  </div>
</section>

<style>
  .featured-collections {
    padding: 3rem 1rem;
    background-color: #ffffff;
  }

  .featured-collections__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .featured-collections__heading {
    font-size: 2rem;
    font-weight: bold;
    text-align: center;
    margin: 0 0 0.5rem 0;
    color: #2a2a2a;
  }

  .featured-collections__subheading {
    font-size: 1rem;
    text-align: center;
    color: #666;
    margin: 0 0 2rem 0;
  }

  .featured-collections__grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 600px) {
    .featured-collections__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .featured-collections__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .collection-card {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .collection-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
  }

  .collection-card__image-wrapper {
    width: 100%;
    height: 300px;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .collection-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .collection-card:hover .collection-card__image {
    transform: scale(1.05);
  }

  .collection-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f0f0f0;
    color: #999;
    font-size: 1rem;
  }

  .collection-card__content {
    padding: 1.5rem;
    text-align: center;
  }

  .collection-card__title {
    font-size: 1.25rem;
    font-weight: bold;
    margin: 0 0 0.5rem 0;
    color: #2a2a2a;
  }

  .collection-card__count {
    font-size: 0.875rem;
    color: #888;
    margin: 0 0 1rem 0;
  }

  .collection-card__button {
    display: inline-block;
    padding: 0.75rem 2rem;
    background-color: #0a0a23;
    color: white;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background-color 0.3s ease;
  }

  .collection-card__button:hover {
    background-color: #1a1a33;
  }
</style>

{% schema %}
{
  "name": "Featured Collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collections"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore our most popular product categories"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Shop Now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collections",
      "blocks": [
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" }
      ]
    }
  ]
}
{% endschema %}
