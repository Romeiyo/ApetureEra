<div class="featured-collections-section">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="featured-collections__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}
    
    {% if section.settings.subheading != blank %}
      <p class="featured-collections__subheading">{{ section.settings.subheading | escape }}</p>
    {% endif %}

    <div class="featured-collections-grid">
      {% for block in section.blocks %}
        {%- assign collection = collections[block.settings.collection] -%}
        
        <div class="collection-card" {{ block.shopify_attributes }}>
          <a href="{{ collection.url }}" class="collection-card__link">
            <div class="collection-card__image-wrapper">
              {% if collection.image %}
                {{ collection.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: collection.title }}
              {% elsif collection.products.first.featured_image %}
                {{ collection.products.first.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: collection.title }}
              {% else %}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
            
            <div class="collection-card__info">
              <h3 class="collection-card__title">{{ collection.title | default: "Example Collection" }}</h3>
              <p class="collection-card__count">{{ collection.products_count | default: 0 }} products</p>
              <span class="collection-card__button">{{ block.settings.button_text }}</span>
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .featured-collections-section {
    background-color: {{ settings.grid_bg_color }}; 
    padding: 60px 0;
    color: #2C1A08; 
  }

  .featured-collections__heading {
    text-align: center;
    color: {{ settings.grid_heading_color }}; 
    font-size: 2.5rem;
    margin-bottom: 10px;
  }
  .featured-collections__subheading {
      text-align: center;
      color: {{ settings.grid_subheading_color }}; 
      font-size: 1.25rem;
      margin-bottom: 40px;
  }
  .featured-collections-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
  }

  @media screen and (min-width: 600px) {
    .featured-collections-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 900px) {
    .featured-collections-grid {
      grid-template-columns: repeat(3, 1fr); 
    }
  }

  .collection-card {
    background: {{ settings.grid_card_bg }};
    border: 1px solid #D4B896;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .collection-card__image-wrapper {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-bottom: 2px solid {{ settings.grid_accent_border }};
  }

  .collection-card__button {
    display: inline-block;
    background-color: {{ settings.grid_heading_color }}; 
    color: #FFFFFF;
    padding: 10px 25px;
    border-radius: 4px;
    font-weight: bold;
    text-transform: uppercase;
    font-size: 0.8rem;
    border: 1px solid {{ settings.grid_heading_color }};
  }
</style>

{% schema %}
{
  "name": "Featured Collections Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Collections"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover quality electronics"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Shop Now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collections Grid",
      "blocks": [
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" }
      ]
    }
  ]
}
{% endschema %}