{% assign water_resistance_rating = product.metafields.custom.water_resistance_rating.value %}
{% assign technical_manual = product.metafields.custom.technical_manual.value %}

{% if water_resistance_rating == true or technical_manual == true %}
  <div class="product-specs-container" style="margin: 20px 0; padding: 15px; border: 1px solid #ddd; border-radius: 8px;">
    
    {% if water_resistance_rating == true %}
      <span style="background: #38a169; color: white; padding: 4px 12px; border-radius: 4px; font-size: 0.85rem; display: inline-block; margin-bottom: 15px;">
        Water Resistant
      </span>
    {% endif %}

    {% if technical_manual %}
      <a href="{{ technical_manual.url }}" target="_blank" download style="display: inline-block; background: #000; color: #fff; padding: 10px 15px; text-decoration: none; border-radius: 4px;">
        📄 Download Technical Manual (PDF)
      </a>
     {% endif %}
    
   </div>
{% endif %}